<odoo>

<record id="cotizacion_form" model="ir.ui.view">
    <field name="name">cotizacion.form</field>
    <field name="model">cotizacion.cotizacion</field>
    <field name="arch" type="xml">

        <form string="Cotizacion Tecnica">

            <header>

                <button
                    name="action_agregar_linea_venta"
                    type="object"
                    string="Añadir linea a orden de venta"
                    class="btn-primary"/>

                <button
                    name="action_ir_orden_venta"
                    type="object"
                    string="Ir a orden de venta"
                    class="btn-secondary"/>

            </header>

            <sheet>

                <!-- Nombre grande -->
                <group>
                    <field name="name"
                        placeholder="Nombre de la cotización"
                        widget="text"/>
                </group>

                <!-- Descripción -->
                <group string="Descripción">
                    <field name="descripcion" nolabel="1"/>
                </group>


                <!-- DATOS TECNICOS Y COSTOS -->
                <group col="2">

                    <!-- Columna izquierda -->
                    <group string="Datos Técnicos">

                        <separator string="Datos técnicos"/>
                        <field name="datos_tecnicos"/>
                        <field name="num_ingenieros"/>
                        <field name="num_tecnicos"/>
                        <field name="num_dias"/>
                        <field name="tiempo_viaje"/>

                    </group>

                    <!-- Columna derecha -->
                    <group string="Costos"
                        invisible="tiempo_viaje == 0">

                        <field name="costo_comida"/>
                        <field name="costo_movilizacion"/>
                        <field name="costo_viaje"/>
                        <field name="costo_hotel"/>
                        <field name="costo_hora_ing"/>
                        <field name="costo_hora_tec"/>

                    </group>

                </group>


                <!-- RESULTADOS Y DATOS ADICIONALES -->
                <group col="2">

                    <!-- Resultados -->
                    <group string="Resultados">

                        <field name="total_laboral_sitio" readonly="1"/>

                        <field name="total_laboral_viaje"
                            readonly="1"
                            invisible="tiempo_viaje == 0"/>

                        <field name="total_viaticos"
                            readonly="1"
                            invisible="tiempo_viaje == 0"/>

                        <field name="total_transporte"
                            readonly="1"
                            invisible="tiempo_viaje == 0"/>

                        <field name="factor_riesgo"/>

                    </group>


                    <!-- Datos adicionales -->
                    <group string="Datos adicionales">

                        <field name="reduccion_standby"
                            invisible="tiempo_viaje == 0"/>

                    </group>

                </group>


                <!-- TOTAL -->
                <group>
                    <field name="total"
                        readonly="1"
                        class="oe_highlight"/>
                </group>

            </sheet>

        </form>

    </field>
</record>

<record id="cotizacion_list" model="ir.ui.view">
    <field name="name">cotizacion.list</field>
    <field name="model">cotizacion.cotizacion</field>
    <field name="arch" type="xml">

        <list string="Cotizaciones">

            <field name="name" string="Nombre"/>

            <field name="descripcion"/>

            <field name="user_id" string="Realizado por"/>

            <field name="sale_line_id"
                string="Linea Orden Venta"/>

            <field name="id"/>

            <field name="total"/>

        </list>

    </field>
</record>


</odoo>